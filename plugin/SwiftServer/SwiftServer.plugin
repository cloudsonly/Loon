[MITM]
hostname = api.revenuecat.com

[URL Rewrite]
^https://api\.revenuecat\.com/v1/subscribers/ header-replace x-revenuecat-etag ""
^https://api\.revenuecat\.com/v1/subscribers/.* response-body-json-replace subscriber.entitlements {"SwiftServer\x20Premium":{"expires_date":"2099-01-01T00:00:00Z","product_identifier":"lifetime.premium.swiftserver","purchase_date":"2023-01-01T00:00:00Z"}}
^https://api\.revenuecat\.com/v1/subscribers/.* response-body-json-replace subscriber.subscriptions {"lifetime.premium.swiftserver":{"expires_date":"2099-01-01T00:00:00Z","purchase_date":"2023-01-01T00:00:00Z"}}
^https://api\.revenuecat\.com/v1/receipts$ response-body-json-replace subscriber.entitlements {"SwiftServer\x20Premium":{"expires_date":"2099-01-01T00:00:00Z","product_identifier":"lifetime.premium.swiftserver","purchase_date":"2023-01-01T00:00:00Z"}}
^https://api\.revenuecat\.com/v1/receipts$ response-body-json-replace subscriber.subscriptions {"lifetime.premium.swiftserver":{"expires_date":"2099-01-01T00:00:00Z","purchase_date":"2023-01-01T00:00:00Z"}}
