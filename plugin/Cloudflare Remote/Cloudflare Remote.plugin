#!name=Cloudflare Remote
#!desc=订阅解锁Premium
#!openUrl = https://apps.apple.com/cn/app/cloudflare-remote/id6743181258
#!author=𝓢𝓪𝓷[https://github.com/cloudsonly?tab=repositories]
#!icon=https://is1-ssl.mzstatic.com/image/thumb/PurpleSource221/v4/a6/ce/1c/a6ce1c56-ca88-8ae4-fd33-bcf8ce7b2b3b/Placeholder.mill/200x200bb-75.webp

[MITM]
hostname = api.revenuecat.com, api-paywalls.revenuecat.com

[URL Rewrite]
^https://api\.revenuecat\.com/v1/subscribers/ header-replace x-revenuecat-etag ""
^https://api\.revenuecat\.com/v1/subscribers/.* response-body-json-add subscriber.entitlements.Premium {"expires_date":"2099-01-01T00:00:00Z","product_identifier":"subscription_cf_lifetime","purchase_date":"2023-01-01T00:00:00Z"}
^https://api\.revenuecat\.com/v1/subscribers/.* response-body-json-add subscriber.subscriptions.subscription_cf_lifetime {"expires_date":"2099-01-01T00:00:00Z","purchase_date":"2023-01-01T00:00:00Z"}
^https://api\.revenuecat\.com/v1/receipts$ response-body-json-add subscriber.entitlements.Premium {"expires_date":"2099-01-01T00:00:00Z","product_identifier":"subscription_cf_lifetime","purchase_date":"2023-01-01T00:00:00Z"}
^https://api\.revenuecat\.com/v1/receipts$ response-body-json-add subscriber.subscriptions.subscription_cf_lifetime {"expires_date":"2099-01-01T00:00:00Z","purchase_date":"2023-01-01T00:00:00Z"}
^https://api-paywalls\.revenuecat\.com/v1/events reject-200
